{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "python scripts/hooks/session_context.py",
        "windows": "python scripts\\hooks\\session_context.py",
        "timeout": 10
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "python scripts/hooks/block_destructive.py",
        "windows": "python scripts\\hooks\\block_destructive.py",
        "timeout": 5
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "python scripts/hooks/check_artifacts.py",
        "windows": "python scripts\\hooks\\check_artifacts.py",
        "timeout": 10
      }
    ]
  }
}
